{
  "name": "ddg-admin",
  "version": "1.0.0",
  "private": true,
  "description": "危险品运输安全监控系统 - 管理端/大屏",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "tsc -b && vite build",
    "build:admin": "tsc -b && vite build --mode admin",
    "build:dashboard": "tsc -b && vite build --mode dashboard",
    "preview": "vite preview --port 5000",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@amap/amap-jsapi-loader": "^1.0.1",
    "@ant-design/icons": "^5.3.0",
    "@ant-design/plots": "^2.2.1",
    "@ant-design/pro-components": "^2.6.49",
    "antd": "^5.15.0",
    "axios": "^1.6.7",
    "dayjs": "^1.11.10",
    "echarts": "^5.5.0",
    "echarts-for-react": "^3.0.2",
    "immer": "^10.0.4",
    "localforage": "^1.10.0",
    "lodash-es": "^4.17.21",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-grid-layout": "^1.4.4",
    "react-router-dom": "^6.22.3",
    "react-use": "^17.5.0",
    "recoil": "^0.7.7",
    "zustand": "^4.5.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.11.28",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/react-grid-layout": "^1.3.5",
    "@vitejs/plugin-react": "^4.2.1",
    "less": "^4.2.0",
    "typescript": "^5.4.2",
    "vite": "^5.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
